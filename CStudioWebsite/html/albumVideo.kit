	<body class='album-body'>


        <section class="container-fluid">
            <div class="row">
               <!-- @include 'navbarsVideo.kit' -->
			   <div class="right-side col-12 col-md-8 col-lg-9 col-xl-10 p-0">
				<div data-aos="fade-left" data-aos-delay="500" class="album-box">

                    <video class="album-frame" controls>
                        <source src="./dist/img/Wedding - 87806.mp4" type="video/mp4">
                    </video>
                    <video class="album-frame" controls>
                        <source src="./dist/img/Wedding - 87806.mp4" type="video/mp4">
